# =============================================================================
# movie-finder — environment template (full stack)
# Copy to .env and fill in all values before running docker compose.
#
#   cp .env.example .env
#
# Never commit .env to version control.
# In production, inject these via Azure Key Vault references or
# Container Apps / App Service environment variable configuration.
# =============================================================================


# =============================================================================
# Qdrant — vector store
# Local dev: leave defaults (docker-compose overrides QDRANT_ENDPOINT).
# Production: point to Qdrant Cloud.
# =============================================================================
QDRANT_ENDPOINT=https://your-cluster.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=movies
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072


# =============================================================================
# LLM — Anthropic (used by chain: classifier, refinement, Q&A agent)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
REASONING_MODEL=claude-sonnet-4-6


# =============================================================================
# OpenAI (used by chain for embeddings)
# =============================================================================
OPENAI_API_KEY=sk-


# =============================================================================
# IMDb API (used by chain via imdbapi-client)
# =============================================================================
IMDB_API_KEY=


# =============================================================================
# JWT authentication (backend)
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
JWT_SECRET=change-me-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# =============================================================================
# LangSmith (optional — tracing and observability)
# =============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=movie-finder
