# Core Platform Identifiers
PROJECT_NAME="Movie Finder API"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SECRET_KEY=generate_a_cryptographically_secure_random_key_here

# Internal Database Nodes
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/moviedb
QDRANT_URL=http://localhost:6333

# External Model Engines
OPENAI_API_KEY=sk-testkey
OLLAMA_BASE_URL=http://192.168.1.100:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# RAG Ingestion Authorizations (Kaggle)
KAGGLE_USERNAME=your_kaggle_account
KAGGLE_KEY=your_kaggle_secret_key

# Observability Configuration (LangSmith)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_trace
LANGCHAIN_PROJECT=movie-finder
