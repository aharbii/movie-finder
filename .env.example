# =============================================================================
# movie-finder — environment template (full stack)
# Copy to .env and fill in all values before running docker compose.
#
#   cp .env.example .env
#
# Never commit .env to version control.
# In production, inject these via Azure Key Vault references.
# =============================================================================


# =============================================================================
# PostgreSQL — session / user database
# docker compose sets POSTGRES_PASSWORD to the same value as DB_PASSWORD.
# =============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=movie_finder
DB_USER=movie_finder
DB_PASSWORD=change-me-generate-a-real-secret
DATABASE_URL=postgresql://movie_finder:change-me-generate-a-real-secret@postgres:5432/movie_finder


# =============================================================================
# Chain provider build profile
#
# Docker build arg consumed by backend/Dockerfile. `default-cloud` keeps the
# deployed Claude/OpenAI/Qdrant image. Use `ollama-qdrant` for local/free
# Ollama chat + embeddings against a matching Qdrant collection.
# =============================================================================
WITH_PROVIDERS=default-cloud


# =============================================================================
# Vector store — shared RAG search backend
#
# Valid VECTOR_STORE: qdrant | chromadb | pinecone | pgvector
# Dynamic target naming: {VECTOR_COLLECTION_PREFIX}_{sanitized_model}_{dimension}
# The selected embedding provider/model/dimension must match RAG ingestion.
#
# QDRANT_API_KEY_RO — read-only key used by backend/chain at query time
# QDRANT_API_KEY_RW — write key used by RAG ingestion at ingest time only
# =============================================================================
VECTOR_STORE=qdrant
VECTOR_COLLECTION_PREFIX=movies
VECTOR_STORE_URL=
VECTOR_STORE_API_KEY=
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY_RO=
QDRANT_API_KEY_RW=
QDRANT_COLLECTION_PREFIX=movies
CHROMADB_PERSIST_PATH=outputs/chromadb/local
PINECONE_API_KEY=
PINECONE_INDEX_NAME=movie-finder-rag
PINECONE_INDEX_HOST=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PGVECTOR_DSN=
PGVECTOR_SCHEMA=public
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072


# =============================================================================
# LLM providers — used by chain through backend runtime config
#
# Valid chat providers: anthropic | openai | groq | together | ollama | google
# =============================================================================
CLASSIFIER_PROVIDER=anthropic
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
REASONING_PROVIDER=anthropic
REASONING_MODEL=claude-sonnet-4-6


# =============================================================================
# Provider API keys
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-
GROQ_API_KEY=
TOGETHER_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434


# =============================================================================
# JWT authentication (backend)
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
APP_SECRET_KEY=change-me-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:4200","https://your-prod-domain.com"]
GLOBAL_RATE_LIMIT=100/minute
AUTH_RATE_LIMIT=5/minute
CHAT_RATE_LIMIT=20/minute
MAX_MESSAGE_LENGTH=2000


# =============================================================================
# LangSmith (optional — tracing and observability)
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="movie-finder"
