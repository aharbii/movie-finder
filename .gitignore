# =============================================================================
# movie-finder — root .gitignore
# =============================================================================

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
*.pem
*.key
*.p12

# ── MkDocs build output ──────────────────────────────────────────────────────
site/

# ── Python artefacts (leaked from backend dev) ───────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
.venv/
venv/
dist/
build/

# ── Node / npm artefacts (frontend) ──────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Docker ───────────────────────────────────────────────────────────────────
*.dockerignore

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.swp
*.swo
*~

# ── Claude Code — session memory ─────────────────────────────────────────────
# Auto-generated by Claude Code across sessions. Contains a mix of project
# context AND personal preferences — never commit.
# Shareable project context belongs in CLAUDE.md instead.
memory/

# ── Coverage / test reports (should not be committed at root level) ───────────
coverage/
*.lcov
*.xml

# ── Structurizr Lite generated files ─────────────────────────────────────────
# (workspace.json is auto-generated by Structurizr Lite from workspace.dsl)
docs/architecture/workspace.json

# ── PlantUML rendered outputs ─────────────────────────────────────────────────
# Source of truth: docs/architecture/plantuml/*.puml (committed).
# PNGs are generated at doc-build time by scripts/prepare-docs.sh and are
# excluded in the docs/ submodule via docs/.gitignore.
# This entry guards against accidental PNG commits at the root level.
docs/architecture/plantuml/*.png
