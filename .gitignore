# =============================================================================
# movie-finder — root .gitignore
# =============================================================================

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
*.pem
*.key
*.p12

# ── MkDocs build output ──────────────────────────────────────────────────────
site/

# ── Python artefacts (leaked from backend dev) ───────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
.venv/
venv/
dist/
build/

# ── Node / npm artefacts (frontend) ──────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Docker ───────────────────────────────────────────────────────────────────
*.dockerignore

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.swp
*.swo
*~

# ── Coverage / test reports (should not be committed at root level) ───────────
coverage/
*.lcov
*.xml

# ── Structurizr Lite generated files ─────────────────────────────────────────
# (workspace.json is auto-generated by Structurizr Lite from workspace.dsl)
docs/architecture/workspace.json
